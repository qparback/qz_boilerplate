# ─── Template for env/.env.{dev,test,prod} ────────────────────────────────────
# Copy this to env/.env.dev (or .test / .prod) and fill in real values.
# This file is COMMITTED — never put real secrets here.
# See env/.env.{dev,test,prod}.config for non-secret config that IS committed.

# ─── Compose interpolation ────────────────────────────────────────────────────
# These are read by docker compose at file-parse time. Must be set in BOTH
# .env.<env>.config and .env.<env> (or just one — they're merged).
PROJECT_NAME=myapp
ENV=dev

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=dev
DOMAIN=myapp.example.com
ADMIN_EMAIL=admin@example.com
ADMIN_IP_WHITELIST=127.0.0.1

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=myapp-db
POSTGRES_PORT=5432
POSTGRES_DB=myapp
POSTGRES_USER=myapp
POSTGRES_PASSWORD=
# Async URL used by the FastAPI app (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://myapp:CHANGE_ME@myapp-db:5432/myapp

# ─── API Security ─────────────────────────────────────────────────────────────
# Generate a strong random key: openssl rand -hex 32
API_KEY=

# ─── Anthropic Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Postmark Email ───────────────────────────────────────────────────────────
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
POSTMARK_FROM_NAME=MyApp

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_TO_DB=true
