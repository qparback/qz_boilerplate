# Non-secret production config — committed.
# Real secrets live in env/.env.prod on the server (gitignored, scp'd separately).

PROJECT_NAME=myapp
ENV=prod
APP_ENV=prod

POSTGRES_HOST=myapp-db
POSTGRES_PORT=5432
POSTGRES_DB=myapp
POSTGRES_USER=myapp

# DOMAIN, ADMIN_EMAIL, ADMIN_IP_WHITELIST set in env/.env.prod (server-specific)

POSTMARK_FROM_NAME=MyApp

LOG_LEVEL=INFO
LOG_TO_DB=true
SCHEDULER_ENABLED=true
