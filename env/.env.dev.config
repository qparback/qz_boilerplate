# Non-secret dev config — committed.
# Real secrets (passwords, API keys) go in env/.env.dev (gitignored).

PROJECT_NAME=myapp
ENV=dev
APP_ENV=dev

POSTGRES_HOST=myapp-db
POSTGRES_PORT=5432
POSTGRES_DB=myapp
POSTGRES_USER=myapp

DOMAIN=localhost
ADMIN_EMAIL=admin@localhost
ADMIN_IP_WHITELIST=127.0.0.1

POSTMARK_FROM_NAME="MyApp Dev"

LOG_LEVEL=DEBUG
LOG_TO_DB=true
SCHEDULER_ENABLED=true
