# Template for the secret half of env files (env/.env.{dev,test,prod}).
# Copy to env/.env.dev (or .test/.prod) and fill in. Never commit the result.

# ─── Database password ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ─── Async database URL (must include the password above) ─────────────────────
DATABASE_URL=postgresql+asyncpg://myapp:CHANGE_ME@myapp-db:5432/myapp

# ─── API security ─────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
API_KEY=

# ─── External services ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=
