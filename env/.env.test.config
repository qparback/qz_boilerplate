# Non-secret test config — committed.
# Test environment uses an isolated DB on port 5433 with tmpfs storage.

PROJECT_NAME=myapp
ENV=test
APP_ENV=test

POSTGRES_HOST=myapp-test-db
POSTGRES_PORT=5432
POSTGRES_DB=myapp_test
POSTGRES_USER=myapp

DOMAIN=test.localhost
ADMIN_EMAIL=test@localhost
ADMIN_IP_WHITELIST=127.0.0.1

POSTMARK_FROM_NAME=MyApp Test

LOG_LEVEL=INFO
LOG_TO_DB=false
SCHEDULER_ENABLED=false
